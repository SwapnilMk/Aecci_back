generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  mobileNumber   String?
  password       String?
  fullName       String?
  country        String?
  userType       String?
  companyName    String?
  
  // OTP Verification
  isEmailVerified Boolean @default(false)
  emailOtp        String?
  emailOtpExpiry  DateTime?


  // Phase 3: Company Profile (Business)
  iecNumber      String?
  gstNumber      String?
  panNumber      String?
  internationalBusinessIds String?
  websiteUrl     String?
  linkedinUrl    String?
  yearEstablished String?
  companySize    String?
  turnover       String?
  industrySector String?
  businessAddress String?
  legalStructure  String?

  // Phase 3: Business Profile (Business)
  businessRole   String?
  products       String[]
  targetMarkets  String[]
  keyCertifications String[]
  experience     String?
  objective      String?

  // Phase 3: Profile (Individual)
  professionalTitle String?
  nationality       String?
  linkedinProfileUrl String?
  yearsOfExperience String?
  aadharNumber      String?
  internationalKycIds String?
  expertiseAreas    String[]
  sectorsOfInterest String[]
  languagesSpoken   String[]

  profilePicture   String?
  // Documents
  iecDocument      String?
  gstDocument      String?
  panDocument      String?
  companyProfileDocument String?
  productCatalogue String[]
  documents        String[]

  kycStatus        String   @default("pending_verification") // pending_verification, approved, active, rejected
  role             String   @default("user") // user, admin, partner
  
  // Post-Onboarding Partner & Pricing Flow
  partnerId        String?  @db.ObjectId
  partner          User?    @relation("PartnerAssignment", fields: [partnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedClients  User[]   @relation("PartnerAssignment")
  paymentStatus    String   @default("pending") // pending, paid
  
  // New Relations for Deal Room Flow
  sessionsHosted   Session[]             @relation("SessionHost")
  registrations    SessionRegistration[]
  questionsAsked   Question[]            @relation("QuestionAuthor")
  questionsAssigned Question[]           @relation("QuestionAssignee")
  reports          OpportunityReport[]
  servicePurchases ServicePurchase[]
  messagesSent     Message[]             @relation("MessageSender")
  messagesReceived Message[]             @relation("MessageReceiver")
  auditLogs        AuditLog[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Session {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  country         String
  marketOverview  String?
  rules           String?
  date            DateTime
  durationMinutes Int
  seatsTotal      Int
  seatsAvailable  Int
  price           Float
  status          String   @default("upcoming") // upcoming, live, completed

  partnerId       String   @db.ObjectId
  partner         User     @relation("SessionHost", fields: [partnerId], references: [id])
  
  registrations   SessionRegistration[]
  reports         OpportunityReport[]
  questions       Question[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SessionRegistration {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  sessionId        String   @db.ObjectId
  paymentStatus    String   @default("pending") // pending, paid
  paymentReference String?
  invoiceUrl       String?
  joinedAt         DateTime?
  
  user             User     @relation(fields: [userId], references: [id])
  session          Session  @relation(fields: [sessionId], references: [id])

  createdAt        DateTime @default(now())
  
  @@unique([userId, sessionId])
}

model CountryIntelligence {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  country               String   @unique
  marketOverview        String
  importRequirements    String
  distributionStructure String
  opportunities         String
  risks                 String
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Question {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // Product, Market, Expansion
  content     String
  status      String   @default("pending") // pending, answered
  answer      String?
  
  userId      String   @db.ObjectId
  user        User     @relation("QuestionAuthor", fields: [userId], references: [id])
  
  partnerId   String?  @db.ObjectId
  partner     User?    @relation("QuestionAssignee", fields: [partnerId], references: [id])
  
  sessionId   String?  @db.ObjectId
  session     Session? @relation(fields: [sessionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OpportunityReport {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  marketSummary     String
  potentialRoutes   String
  recommendations   String
  pdfUrl            String?
  
  userId            String   @db.ObjectId
  user              User     @relation(fields: [userId], references: [id])
  
  sessionId         String   @db.ObjectId
  session           Session  @relation(fields: [sessionId], references: [id])

  createdAt         DateTime @default(now())
}

model ServicePurchase {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  serviceType    String   // Advisory, Documentation, Partner Coordination, Market Entry
  price          Float
  paymentStatus  String   @default("pending") // pending, paid, invoiced
  invoiceUrl     String?
  
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now())
}

model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   @default("notification") // support, partner, notification
  subject     String?
  content     String
  isRead      Boolean  @default(false)
  
  senderId    String?  @db.ObjectId // Optional: system notifications have no sender
  sender      User?    @relation("MessageSender", fields: [senderId], references: [id])
  
  receiverId  String   @db.ObjectId
  receiver    User     @relation("MessageReceiver", fields: [receiverId], references: [id])

  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  action      String   // e.g., 'accepted_booking_terms', 'joined_live_room'
  ipAddress   String?
  metadata    Json?    // Stores browser info, timestamps, exact terms agreed to
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}
